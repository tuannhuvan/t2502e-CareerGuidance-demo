@model IEnumerable<CareerGuidance.Models.TestResult>

@{
    ViewData["Title"] = "My Test Results";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h2 mb-2">My Test Results</h1>
            <p class="text-muted">View all your assessment results and recommended career paths</p>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var result in Model.OrderByDescending(r => r.CompletedAt))
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@result.Test?.Title</h5>
                            <div class="row">
                                <div class="col-md-6">
                                    <small class="text-muted">Score:</small>
                                    <h4>@result.Score</h4>
                                </div>
                                <div class="col-md-6">
                                    <small class="text-muted">Completed:</small>
                                    <p>@result.CompletedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </div>
                            @if (result.RecommendedCareerPath != null)
                            {
                                <div class="mt-3">
                                    <small class="text-muted">Recommended Career Path:</small>
                                    <p>@result.RecommendedCareerPath.Title</p>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-light">
                            <a href="@Url.Action("Details", new { id = result.Id })" class="btn btn-sm btn-info">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <p>You haven't completed any tests yet. <a href="@Url.Action("Index")">Start a test now</a></p>
        </div>
    }
</div>
