@{
    ViewData["Title"] = "Test Results";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-lg">
                <div class="card-header bg-success text-white">
                    <h3 class="card-title mb-0">Test Completed!</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info" role="alert">
                        <h4 class="alert-heading">Your Result</h4>
                        <p id="resultMessage">Loading your results...</p>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h5>Score</h5>
                            <h2 id="scoreDisplay">--</h2>
                        </div>
                        <div class="col-md-6">
                            <h5>Recommended Career Path</h5>
                            <p id="careerPathDisplay">Loading...</p>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h5>Resources for You</h5>
                        <div id="resourcesList">
                            <!-- Resources will be loaded here -->
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light">
                    <a href="@Url.Action("Index")" class="btn btn-primary">Take Another Test</a>
                    <a href="@Url.Action("MyResults")" class="btn btn-secondary">View All Results</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/test-results.js"></script>
}
