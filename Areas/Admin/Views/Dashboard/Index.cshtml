@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Dashboard</h1>
        <p class="text-muted">Hệ thống hướng nghiệp trực tuyến - Khu vực quản trị</p>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>CRUD</h3>
                <p>Quản lý bài test trắc nghiệm</p>
            </div>
            <a asp-area="Admin" asp-controller="Tests" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>Danh mục</h3>
                <p>Phân loại ngành nghề vĩ mô</p>
            </div>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>Lộ trình</h3>
                <p>Nội dung hướng nghiệp chi tiết</p>
            </div>
            <a asp-area="Admin" asp-controller="CareerPaths" asp-action="Index" class="small-box-footer">Xem chi tiết <i class="bi bi-arrow-right"></i></a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">Tài khoản mẫu (Development)</h3></div>
    <div class="card-body">
        <ul>
            <li><strong>Admin:</strong> admin@careerguidance.com / Admin@123</li>
            <li><strong>Student:</strong> student@careerguidance.com / Student@123</li>
        </ul>
    </div>
</div>
