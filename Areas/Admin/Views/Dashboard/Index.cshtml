@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="h3 mb-3">Admin Dashboard</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Tests</h5>
                    <h2>@ViewBag.TotalTests</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Career Paths</h5>
                    <h2>@ViewBag.TotalCareerPaths</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">Test Results</h5>
                    <h2>@ViewBag.TotalResults</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Categories</h5>
                    <h2>@ViewBag.TotalCategories</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Management</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">
                            <a href="@Url.Action("Index", "Tests")" class="btn btn-sm btn-primary">Manage Tests</a>
                        </li>
                        <li class="list-group-item">
                            <a href="@Url.Action("Index", "Categories")" class="btn btn-sm btn-success">Manage Categories</a>
                        </li>
                        <li class="list-group-item">
                            <a href="@Url.Action("Index", "CareerPaths")" class="btn btn-sm btn-info">Manage Career Paths</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
