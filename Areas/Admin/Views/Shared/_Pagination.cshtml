@model CareerGuidance.Helpers.PaginatedList<object>
@{
    dynamic list = Model;
}

@if (list.TotalPages > 1)
{
    var prevDisabled = !list.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !list.HasNextPage ? "disabled" : "";

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @prevDisabled">
                <a class="page-link" asp-action="Index"
                   asp-route-pageIndex="@(list.PageIndex - 1)"
                   asp-route-Keyword="@ViewData["Keyword"]"
                   asp-route-DateRange="@ViewData["DateRange"]"
                   asp-route-SortOrder="@ViewData["SortOrder"]"
                   asp-route-Status="@ViewData["Status"]"
                   asp-route-CategoryId="@ViewData["CategoryId"]">Trước</a>
            </li>
            @for (int i = 1; i <= list.TotalPages; i++)
            {
                <li class="page-item @(i == list.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageIndex="@i"
                       asp-route-Keyword="@ViewData["Keyword"]"
                       asp-route-DateRange="@ViewData["DateRange"]"
                       asp-route-SortOrder="@ViewData["SortOrder"]"
                       asp-route-Status="@ViewData["Status"]"
                       asp-route-CategoryId="@ViewData["CategoryId"]">@i</a>
                </li>
            }
            <li class="page-item @nextDisabled">
                <a class="page-link" asp-action="Index"
                   asp-route-pageIndex="@(list.PageIndex + 1)"
                   asp-route-Keyword="@ViewData["Keyword"]"
                   asp-route-DateRange="@ViewData["DateRange"]"
                   asp-route-SortOrder="@ViewData["SortOrder"]"
                   asp-route-Status="@ViewData["Status"]"
                   asp-route-CategoryId="@ViewData["CategoryId"]">Sau</a>
            </li>
        </ul>
    </nav>
}
